GEMINI_API_KEY=YOUR_GEMINI_API_KEY
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Google Cloud Storage (for automated backups)
# Create a bucket at console.cloud.google.com -> Cloud Storage -> Buckets
# Place your Service Account key file as 'gcp-backup-key.json' in the project root
GCP_BUCKET_NAME=YOUR_GCS_BUCKET_NAME
TG_API_ID=YOUR_TELEGRAM_API_ID
TG_API_HASH=YOUR_TELEGRAM_API_HASH


BYBIT_API_KEY=YOUR_BYBIT_API_KEY
BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET
IS_BYBIT_TESTNET=True

# --- Nexus Sources Configuration (Sentiment) ---
# Gmail: Search query for macro reports
GMAIL_QUERY=YOUR_GMAIL_QUERY
GMAIL_SOURCE_NAME=YOUR_MACRO_SOURCE

# Telegram: Public URL of the channel to scrape (t.me/s/NAME)
TG_CHANNEL_URL=https://t.me/s/YOUR_CHANNEL_ID

# Telegram Video Bridge: Private/VIP channel to monitor for video analysis
TG_VIDEO_CHANNEL=YOUR_VIP_CHANNEL
